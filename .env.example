# Required secrets
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
STRATZ_API_TOKEN=
STEAM_API_TOKEN=

# Active Spring profile
SPRING_PROFILES_ACTIVE=prod

# Optional datasource override (if you switch from embedded H2 file)
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# Optional tuning
DAY_START_HOUR=3
DAY_TIMEZONE=Europe/Moscow
TELEGRAM_NOTIFICATION_SCHEDULER_DAILY_MESSAGE_STATS_CRON=0 0 0 * * *
INGESTION_STRATZ_HISTORICAL_START=1767225600
INGESTION_STRATZ_MATCHES_LIMIT=20

# JVM tuning for small VPS
JAVA_OPTS=-XX:MaxRAMPercentage=70.0 -XX:InitialRAMPercentage=20.0 -Dfile.encoding=UTF-8
